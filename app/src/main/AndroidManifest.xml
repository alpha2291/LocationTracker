<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keep worker alive -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Mi/OnePlus autostart (these are OEM-specific, declared but not guaranteed) -->
    <uses-permission android:name="com.miui.securitycenter.permission.AppPermissionsEditor"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="oppo.permission.OPPO_COMPONENT_SAFE"
        tools:ignore="ProtectedPermissions" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LocationTrackerPlayer">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LocationTrackerPlayer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service for location tracking -->
        <service
            android:name=".background.LocationForegroundService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <!-- Boot receiver to restart worker after reboot -->
        <receiver
            android:name=".background.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <!-- Xiaomi/MIUI -->
                <action android:name="com.miui.securitycenter.ACTION_APPLICATION_PERMISSIONS_CHANGED"
                    tools:ignore="ChromeOsAbiSupport" />
                <!-- OnePlus -->
                <action android:name="android.intent.action.REBOOT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>